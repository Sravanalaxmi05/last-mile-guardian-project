# Required for live Gemma 4
REQUIRE_GEMMA4=true
GEMMA_PROVIDER=google-ai
GEMMA_MODEL_ID=replace_with_actual_gemma_4_model_id
GOOGLE_API_KEY=replace_with_key

# Alternative for open-weight hosted Gemma 4
# GEMMA_PROVIDER=openai-compatible
# GEMMA_BASE_URL=https://your-provider.example/v1
# GEMMA_OPENAI_COMPAT_API_KEY=replace_with_key

# Demo fallback
ENABLE_DEMO_MODE=true
